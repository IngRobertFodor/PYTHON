# Fodor Travel TIPs - Environment Variables
# Copy this file to .env and fill in values

# Flask settings
FLASK_DEBUG=True
PORT=5000

# No API keys needed! All APIs used are free and open.
# - Overpass API (OpenStreetMap) - no key
# - Nominatim (geocoding) - no key
# - Wikipedia REST API - no key
# - Wikidata API - no key
# - Open-Meteo (weather) - no key
# - OSRM (routing) - no key